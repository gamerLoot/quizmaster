# MongoDB Atlas free-tier connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/quizmaster?retryWrites=true&w=majority

# Any long random string (used to sign login sessions) — generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string

# Used only once by `npm run seed:admin` to create the initial Super Admin account
SUPER_ADMIN_NAME=Your Name
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=ChangeMe123!
